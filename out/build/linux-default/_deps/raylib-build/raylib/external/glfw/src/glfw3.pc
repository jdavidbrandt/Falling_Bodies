prefix=/workspaces/raylib_cube/out/install/linux-default
exec_prefix=${prefix}
includedir=/workspaces/raylib_cube/out/install/linux-default/include
libdir=/workspaces/raylib_cube/out/install/linux-default/lib

Name: GLFW
Description: A multi-platform library for OpenGL, window and input
Version: 3.4.0
URL: https://www.glfw.org/
Requires.private: 
Libs: -L${libdir} -lglfw3
Libs.private:  -lrt -lm -ldl
Cflags: -I${includedir}
